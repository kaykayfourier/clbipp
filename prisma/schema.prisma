generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Chemistry {
  LFP
  NMC622
  NMC811
  LCO
}

enum Pathway {
  REUSE
  REFURBISH
  RECYCLE
}

model BatteryPack {
  id          String @id @default(uuid())
  packAadhaar String @unique @map("pack_aadhaar")
  weightKg    Decimal? @db.Decimal(8, 2) @map("weight_kg")
  chemistry Chemistry

  manufacturer String?
  modelNumber  String? @map("model_number")

  nominalCapacityKwh Decimal? @db.Decimal(8, 2) @map("nominal_capacity_kwh")

nominalVoltage Decimal? @db.Decimal(8, 2) @map("nominal_voltage")


  manufactureDate DateTime? @map("manufacture_date")

  createdAt DateTime @default(now()) @map("created_at")

  inspections BatteryInspection[]
  decisions   PathwayDecision[]

  @@map("battery_packs")
}

model BatteryInspection {
  id String @id @default(uuid())

  packId String @map("pack_id")

  inspectionTimestamp DateTime @default(now()) @map("inspection_timestamp")

  inspectorId String? @map("inspector_id")

  visualScore  Int? @map("visual_score")
  leakageScore Int? @map("leakage_score")
  thermalScore Int? @map("thermal_score")

  damageScore Decimal? @db.Decimal(4, 2) @map("damage_score")

  sohPct Decimal? @db.Decimal(5, 2) @map("soh_pct")

  socPct Decimal? @db.Decimal(5, 2) @map("soc_pct")

  entropyValue Decimal? @db.Decimal(8, 4) @map("entropy_value")

  entropyAnomaliesCount Int @default(0) @map("entropy_anomalies_count")

  irImbalanceRatio Decimal? @db.Decimal(6, 3) @map("ir_imbalance_ratio")

  voltageImbalanceMv Decimal? @db.Decimal(6, 1) @map("voltage_imbalance_mv")

  tempMaxC Decimal? @db.Decimal(5, 2) @map("temp_max_c")

  cycleCount Int? @map("cycle_count")

  rulMonths Int? @map("rul_months")

  notes String?

  pack BatteryPack @relation(fields: [packId], references: [id], onDelete: Cascade)

  diagnostics BatteryDiagnostic[]
  decisions   PathwayDecision[]

  @@map("battery_inspections")
}

model BatteryDiagnostic {
  id String @id @default(uuid())

  inspectionId String @map("inspection_id")

  cellDataSnapshot Json? @map("cell_data_snapshot")

  createdAt DateTime @default(now()) @map("created_at")

  inspection BatteryInspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  @@map("battery_diagnostics")
}

model PathwayFactor {
  id String @id @default(uuid())

  configVersion String @map("config_version")

  processingRatePerKg Decimal? @map("processing_rate_per_kg")

  refurbLaborRatePerKg Decimal? @map("refurb_labor_rate_per_kg")

  cellReplacementRate Decimal? @map("cell_replacement_rate")

  ageCap      Int? @map("age_cap")
  cycleCap      Int? @map("cycle_cap")

  testingRatePerKg Decimal? @map("testing_rate_per_kg")

  hydrometRatePerKg Decimal? @map("hydromet_rate_per_kg")

  metalPrices Json? @map("metal_prices")

  chemistryComposition Json? @map("chemistry_composition")

  isActive Boolean @default(true) @map("is_active")

  effectiveFrom DateTime? @map("effective_from")

  effectiveTo DateTime? @map("effective_to")

  createdAt DateTime @default(now()) @map("created_at")

  decisions PathwayDecision[]

  @@map("pathway_factors")
}

model PathwayDecision {
  id String @id @default(uuid())

  packId String @map("pack_id")

  inspectionId String @map("inspection_id")

  factorConfigId String @map("factor_config_id")

  pathway Pathway

  costBreakdown Json? @map("cost_breakdown")

  revenueBreakdown Json? @map("revenue_breakdown")

  netRevenue Decimal? @db.Decimal(12, 2) @map("net_revenue")

  costsTotal Decimal? @db.Decimal(12, 2) @map("costs_total")

  pMin Decimal? @db.Decimal(12, 2) @map("p_min")

  pRecommended Decimal? @db.Decimal(12, 2) @map("p_recommended")

  pMax Decimal? @db.Decimal(12, 2) @map("p_max")

  confidenceScore Decimal? @db.Decimal(4, 3) @map("confidence_score")

  decisionRationale String? @map("decision_rationale")

  createdAt DateTime @default(now()) @map("created_at")

  pack BatteryPack @relation(fields: [packId], references: [id])

  inspection BatteryInspection @relation(fields: [inspectionId], references: [id])

  factorConfig PathwayFactor @relation(fields: [factorConfigId], references: [id])

  @@map("pathway_decisions")
}
